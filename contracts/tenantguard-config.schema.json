{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenantguard.dev/contracts/tenantguard-config.schema.json",
  "title": "TenantGuard Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "enum": ["low", "medium", "high", "critical"]
          },
          "suppressions": {
            "type": "array",
            "items": { "$ref": "#/$defs/suppression" }
          }
        }
      }
    },
    "specs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "enum": ["auto", "off", "spec-kit"]
        }
      }
    }
  },
  "$defs": {
    "suppression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason", "owner"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "finding_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "expires": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "anyOf": [
        { "required": ["path"] },
        { "required": ["finding_id"] }
      ]
    }
  }
}
