{
  "name": "@tenantguard/github-app",
  "version": "0.0.0",
  "description": "TenantGuard report-only GitHub App — runs the review-pr chain on a PR and posts a Checks run + annotations (no repository mutation)",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tenantguard/config": "workspace:*",
    "@tenantguard/review": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
