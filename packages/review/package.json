{
  "name": "@tenantguard/review",
  "version": "0.0.0",
  "description": "TenantGuard PR Reviewer — review a local diff or GitHub PR against the SaaS gates and declared scope, returning a Ready / Not Ready / Needs Verification verdict",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tenantguard/config": "workspace:*",
    "@tenantguard/gates": "workspace:*",
    "@tenantguard/project-map": "workspace:*",
    "@tenantguard/queue": "workspace:*",
    "@tenantguard/scanner": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
